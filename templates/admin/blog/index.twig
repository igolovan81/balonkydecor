{% extends "layout/admin-base.twig" %}
{% block title %}{{ t('blog.title') }}{% endblock %}
{% block content %}
<div class="admin-topbar">
    <h1>{{ t('blog.title') }}</h1>
    <a href="/admin/blog/new" class="btn btn-primary">{{ t('blog.add') }}</a>
</div>
<table class="admin-table">
    <thead>
        <tr>
            <th>{{ t('blog.col.id') }}</th>
            <th>{{ t('blog.col.slug') }}</th>
            <th>{{ t('blog.col.status') }}</th>
            <th>{{ t('blog.col.date') }}</th>
            <th>{{ t('blog.col.actions') }}</th>
        </tr>
    </thead>
    <tbody>
    {% for p in posts %}
    <tr>
        <td>{{ p.id }}</td>
        <td>{{ p.slug }}</td>
        <td><span class="badge badge-{{ p.status == 'published' ? 'paid' : 'pending' }}">{{ p.status }}</span></td>
        <td>{{ p.published_at ?? '—' }}</td>
        <td>
            <a href="/admin/blog/{{ p.id }}/edit">{{ t('blog.edit') }}</a> |
            <form method="POST" action="/admin/blog/{{ p.id }}/delete" style="display:inline" onsubmit="return confirm('Smazat příspěvek?')">
                <button class="btn-link">{{ t('blog.delete') }}</button>
            </form>
        </td>
    </tr>
    {% else %}
    <tr><td colspan="5">{{ t('blog.no_posts') }}</td></tr>
    {% endfor %}
    </tbody>
</table>
{% if pages > 1 %}
<div class="pagination" style="margin-top:1rem;">
    {% for p in 1..pages %}
    <a href="?page={{ p }}" class="{% if p == page %}active{% endif %}">{{ p }}</a>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
