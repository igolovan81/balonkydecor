<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Přihlášení — BalonkyDecor Admin</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body class="admin-login-page">
<div class="login-box">
    <h1>BalonkyDecor Admin</h1>
    {% if error %}<p class="form-error">{{ error }}</p>{% endif %}
    {% if flash %}<div class="flash-{{ flash.type }}">{{ flash.message }}</div>{% endif %}
    <form method="POST" action="/admin/login">
        <div class="form-group">
            <label>E-mail</label>
            <input type="email" name="email" required autofocus>
        </div>
        <div class="form-group">
            <label>Heslo</label>
            <input type="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Přihlásit se</button>
    </form>
</div>
</body>
</html>
