{% extends "layout/admin-base.twig" %}
{% block title %}{{ t('services.title') }}{% endblock %}
{% block content %}
<div class="admin-topbar">
    <h1>{{ t('services.title') }}</h1>
    <a href="/admin/services/new" class="btn btn-primary">{{ t('services.add') }}</a>
</div>
<table class="admin-table" data-sortable>
    <thead>
        <tr>
            <th><button type="button" class="sort-btn" data-sort-type="number">{{ t('services.col.id') }}</button></th>
            <th><button type="button" class="sort-btn" data-sort-type="text">{{ t('services.col.name') }}</button></th>
            <th><button type="button" class="sort-btn" data-sort-type="number">{{ t('services.col.price') }}</button></th>
            <th><button type="button" class="sort-btn" data-sort-type="number">{{ t('services.col.order') }}</button></th>
            <th><button type="button" class="sort-btn" data-sort-type="text">{{ t('services.col.updated_by') }}</button></th>
            <th><button type="button" class="sort-btn" data-sort-type="text">{{ t('services.col.updated') }}</button></th>
            <th>{{ t('services.col.actions') }}</th>
        </tr>
    </thead>
    <tbody>
    {% for service in services %}
    <tr>
        <td>{{ service.id }}</td>
        <td>{{ service.name ?? '—' }}</td>
        <td data-sort-value="{{ service.price_from ?? -1 }}">{{ service.price_from ? service.price_from ~ ' Kč' : '—' }}</td>
        <td>{{ service.sort_order }}</td>
        <td>{{ service.updated_by_email ?? t('common.audit.unknown_user') }}</td>
        <td class="audit-meta">{{ service.updated_at }}</td>
        <td>
            <a href="/admin/services/{{ service.id }}/edit">{{ t('services.edit') }}</a> |
            <form method="POST" action="/admin/services/{{ service.id }}/delete" style="display:inline" onsubmit="return confirm('{{ t('services.confirm_delete') }}')">
                <button class="btn-link">{{ t('services.delete') }}</button>
            </form>
        </td>
    </tr>
    {% else %}
    <tr><td colspan="7">{{ t('services.no_services') }}</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
