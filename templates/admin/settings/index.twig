{% extends "layout/admin-base.twig" %}
{% block title %}{{ t('settings.title') }}{% endblock %}
{% block content %}
<div class="admin-topbar"><h1>{{ t('settings.title') }}</h1></div>
<form method="POST" action="/admin/settings" class="admin-form">
    <h3>{{ t('settings.web') }}</h3>
    <div class="form-group">
        <label>{{ t('settings.site_name') }}</label>
        <input type="text" name="site_name" value="{{ settings.site_name ?? '' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.contact_email') }}</label>
        <input type="email" name="contact_email" value="{{ settings.contact_email ?? '' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.phone') }}</label>
        <input type="text" name="contact_phone" value="{{ settings.contact_phone ?? '' }}">
    </div>

    <h3>{{ t('settings.smtp') }}</h3>
    <div class="form-group">
        <label>{{ t('settings.smtp_host') }}</label>
        <input type="text" name="smtp_host" value="{{ settings.smtp_host ?? '' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.smtp_port') }}</label>
        <input type="number" name="smtp_port" value="{{ settings.smtp_port ?? '587' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.smtp_user') }}</label>
        <input type="text" name="smtp_user" value="{{ settings.smtp_user ?? '' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.smtp_pass') }}</label>
        <input type="password" name="smtp_pass" value="{{ settings.smtp_pass ?? '' }}" autocomplete="new-password">
    </div>
    <div class="form-group">
        <label>{{ t('settings.smtp_from') }}</label>
        <input type="email" name="smtp_from" value="{{ settings.smtp_from ?? '' }}">
    </div>

    <h3>{{ t('settings.gopay') }}</h3>
    <p style="color:#666;font-size:0.9rem;">{{ t('settings.gopay_hint') }}</p>
    <div class="form-group">
        <label>{{ t('settings.gopay_go_id') }}</label>
        <input type="text" name="gopay_go_id" value="{{ settings.gopay_go_id ?? '' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.client_id') }}</label>
        <input type="text" name="gopay_client_id" value="{{ settings.gopay_client_id ?? '' }}">
    </div>
    <div class="form-group">
        <label>{{ t('settings.client_secret') }}</label>
        <input type="password" name="gopay_client_secret" value="{{ settings.gopay_client_secret ?? '' }}" autocomplete="new-password">
    </div>
    <div class="form-group">
        <label>
            <input type="checkbox" name="gopay_test_mode" value="1" {% if settings.gopay_test_mode != '0' %}checked{% endif %}>
            {{ t('settings.test_mode') }}
        </label>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{ t('settings.save') }}</button>
    </div>
</form>
{% endblock %}
