{% extends "layout/admin-base.twig" %}
{% block title %}{{ t('users.title') }}{% endblock %}
{% block content %}
<div class="admin-topbar">
    <h1>{{ t('users.title') }}</h1>
    <a href="/admin/users/new" class="btn btn-primary">{{ t('users.add') }}</a>
</div>
<table class="admin-table">
    <thead>
        <tr>
            <th>{{ t('users.col.id') }}</th>
            <th>{{ t('users.col.email') }}</th>
            <th>{{ t('users.col.role') }}</th>
            <th>{{ t('users.col.created') }}</th>
            <th>{{ t('users.col.actions') }}</th>
        </tr>
    </thead>
    <tbody>
    {% for u in users %}
    <tr>
        <td>{{ u.id }}</td>
        <td>{{ u.email }}</td>
        <td>{{ u.role }}</td>
        <td>{{ u.created_at }}</td>
        <td>
            <form method="POST" action="/admin/users/{{ u.id }}/password" style="display:inline-flex;gap:0.4rem;align-items:center;">
                <input type="password" name="password" placeholder="{{ t('users.new_password') }}" minlength="8" style="width:140px;">
                <button type="submit" class="btn btn-secondary" style="padding:0.3rem 0.6rem;font-size:0.85rem;">{{ t('users.change_password') }}</button>
            </form>
            |
            <form method="POST" action="/admin/users/{{ u.id }}/delete" style="display:inline" onsubmit="return confirm('{{ t('users.confirm_delete') }}')">
                <button class="btn-link">{{ t('users.delete') }}</button>
            </form>
        </td>
    </tr>
    {% else %}
    <tr><td colspan="5">{{ t('users.no_users') }}</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
