{% extends "layout/admin-base.twig" %}
{% block title %}{{ t('users.form.title_new') }}{% endblock %}
{% block content %}
<div class="admin-topbar">
    <h1>{{ t('users.form.title_new') }}</h1>
    <a href="/admin/users" class="btn btn-secondary">{{ t('users.form.back') }}</a>
</div>
<form method="POST" action="/admin/users/new" class="admin-form">
    <div class="form-group">
        <label>{{ t('users.form.email') }}</label>
        <input type="email" name="email" required autofocus>
    </div>
    <div class="form-group">
        <label>{{ t('users.form.password') }}</label>
        <input type="password" name="password" required minlength="8">
    </div>
    <div class="form-group">
        <label>{{ t('users.form.role') }}</label>
        <select name="role">
            <option value="admin">Admin</option>
            <option value="editor">Editor</option>
        </select>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{ t('users.form.create') }}</button>
        <a href="/admin/users" class="btn btn-secondary">{{ t('users.form.cancel') }}</a>
    </div>
</form>
{% endblock %}
