{% extends "layout/admin-base.twig" %}
{% block title %}{{ t('orders.detail.title') }} {{ order.order_number }}{% endblock %}
{% block content %}
<div class="admin-topbar">
    <h1>{{ t('orders.detail.title') }} {{ order.order_number }}</h1>
    <a href="/admin/orders" class="btn btn-secondary">{{ t('orders.detail.back') }}</a>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;">
<div class="admin-form">
    <h3>{{ t('orders.detail.customer') }}</h3>
    <p><strong>{{ t('orders.detail.name') }}</strong> {{ order.customer_name }}</p>
    <p><strong>{{ t('orders.detail.email') }}</strong> {{ order.customer_email }}</p>
    <p><strong>{{ t('orders.detail.phone') }}</strong> {{ order.customer_phone }}</p>
    <p><strong>{{ t('orders.detail.pickup_date') }}</strong> {{ order.pickup_date ?? '—' }}</p>
    <p><strong>{{ t('orders.detail.notes') }}</strong> {{ order.notes ?? '—' }}</p>
    <p><strong>{{ t('orders.detail.gopay_id') }}</strong> {{ order.gopay_payment_id ?? '—' }}</p>
    <p><strong>{{ t('orders.detail.created') }}</strong> {{ order.created_at }}</p>
    <hr style="margin:1rem 0;">
    <h3>{{ t('orders.detail.change_status') }}</h3>
    <form method="POST" action="/admin/orders/{{ order.order_number }}/status" style="display:flex;gap:0.5rem;align-items:center;">
        <select name="status">
            {% for s in statuses %}
            <option value="{{ s }}" {% if s == order.status %}selected{% endif %}>{{ t('orders.status.' ~ s) }}</option>
            {% endfor %}
        </select>
        <button type="submit" class="btn btn-primary">{{ t('orders.detail.save') }}</button>
    </form>
</div>
<div>
    <table class="admin-table">
        <thead><tr><th>{{ t('orders.detail.col.product') }}</th><th>{{ t('orders.detail.col.qty') }}</th><th>{{ t('orders.detail.col.unit_price') }}</th><th>{{ t('orders.detail.col.total') }}</th></tr></thead>
        <tbody>
        {% for item in order.items %}
        <tr>
            <td>{{ item.product_name_snapshot }}</td>
            <td>{{ item.quantity }}</td>
            <td>{{ item.unit_price|number_format(2, '.', ' ') }} Kč</td>
            <td>{{ (item.unit_price * item.quantity)|number_format(2, '.', ' ') }} Kč</td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="summary-total" style="margin-top:0.5rem;">
        <span>{{ t('orders.detail.col.total') }}</span>
        <strong>{{ order.total_amount|number_format(2, '.', ' ') }} Kč</strong>
    </div>
</div>
</div>
{% endblock %}
