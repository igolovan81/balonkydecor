<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} — BalonkyDecor</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/admin.css">
    {% block head %}{% endblock %}
</head>
<body class="admin-body">
    <aside class="admin-sidebar">
        <div class="admin-logo">BalonkyDecor</div>
        <nav class="admin-nav">
            <a href="/admin">{{ t('nav.dashboard') }}</a>
            <a href="/admin/products">{{ t('nav.products') }}</a>
            <a href="/admin/categories">{{ t('nav.categories') }}</a>
            <a href="/admin/orders">{{ t('nav.orders') }}</a>
            <a href="/admin/gallery">{{ t('nav.gallery') }}</a>
            <a href="/admin/blog">{{ t('nav.blog') }}</a>
            <a href="/admin/pages">{{ t('nav.pages') }}</a>
            <a href="/admin/settings">{{ t('nav.settings') }}</a>
            {% if session_role == 'admin' %}<a href="/admin/users">{{ t('nav.users') }}</a>{% endif %}
        </nav>
        <div style="margin-top:auto;padding:1rem;border-top:1px solid rgba(255,255,255,0.1);">
            <div style="font-size:0.8rem;color:#a0a0b8;margin-bottom:0.25rem;">{{ session_email }}</div>
            <div style="font-size:0.75rem;color:#6060a0;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">{{ session_role }}</div>
            <div class="admin-lang-switcher">
                {% for code, label in {cs: 'CZ', sk: 'SK', en: 'EN', uk: 'UA', ru: 'RU'} %}
                    <a href="/admin/set-lang?l={{ code }}"{% if admin_lang == code %} class="active"{% endif %}>{{ label }}</a>
                {% endfor %}
            </div>
            <a href="/admin/logout" style="color:#c0c0d0;font-size:0.85rem;">{{ t('nav.logout') }}</a>
        </div>
    </aside>
    <main class="admin-main">
        {% if flash %}
            <div class="flash-{{ flash.type }}">{{ flash.message }}</div>
        {% endif %}
        {% block content %}{% endblock %}
    </main>
    {% block scripts %}{% endblock %}
</body>
</html>
